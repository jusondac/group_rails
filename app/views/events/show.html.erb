<div class="container px-4 py-8 mx-auto">
  <div class="flex items-center gap-2 text-gray-500 dark:text-gray-400 mb-6">
    <%= link_to @community.name, community_path(@community), class: "hover:text-blue-600 dark:hover:text-blue-400" %>
    <svg class="w-3 h-3" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 6 10">
      <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 9 4-4-4-4"/>
    </svg>
    <%= link_to "Events", community_events_path(@community), class: "hover:text-blue-600 dark:hover:text-blue-400" %>
    <svg class="w-3 h-3" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 6 10">
      <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 9 4-4-4-4"/>
    </svg>
    <span class="text-gray-700 dark:text-gray-300"><%= @event.name %></span>
  </div>
  <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md overflow-hidden border border-gray-200 dark:border-gray-700">
    <div class="p-6">
      <div class="flex justify-between items-start flex-wrap gap-4">
        <div>
          <h1 class="text-2xl font-bold dark:text-white"><%= @event.name %></h1>
          <div class="mt-1 flex flex-wrap gap-2">
            <% if @event.private? %>
              <span class="bg-amber-100 text-amber-800 text-xs font-medium px-2.5 py-0.5 rounded">Private Event</span>
            <% else %>
              <span class="bg-green-100 text-green-800 text-xs font-medium px-2.5 py-0.5 rounded">Public Event</span>
            <% end %>
            <span class="bg-blue-100 text-blue-800 text-xs font-medium px-2.5 py-0.5 rounded">
              <%= @event.users.count %> <%= 'Participant'.pluralize(@event.users.count) %>
            </span>
          </div>
        </div>
        <div class="space-x-2">
          <% if Current.user.admin_of?(@community) %>
            <%= link_to "Edit", edit_community_event_path(@community, @event), class: "bg-blue-600 hover:bg-blue-700 text-white font-medium py-2 px-4 rounded-lg" %>
            <%= button_to "Delete", community_event_path(@community, @event), method: :delete, 
                data: { confirm: "Are you sure you want to delete this event?" }, 
                class: "bg-red-600 hover:bg-red-700 text-white font-medium py-2 px-4 rounded-lg" %>
          <% end %>
        </div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mt-6">
        <div class="md:col-span-2">
          <div class="bg-gray-50 dark:bg-gray-700 p-4 rounded-lg mb-6">
            <div class="flex items-center mb-4">
              <svg class="w-5 h-5 text-gray-500 dark:text-gray-400 mr-2" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
                <path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd"></path>
              </svg>
              <span class="text-gray-700 dark:text-gray-300 font-medium"><%= @event.time_range %></span>
            </div>
            <% if @event.location.present? %>
              <div class="flex items-center">
                <svg class="w-5 h-5 text-gray-500 dark:text-gray-400 mr-2" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
                  <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"></path>
                </svg>
                <span class="text-gray-700 dark:text-gray-300"><%= @event.location %></span>
              </div>
            <% end %>
          </div>
          <div>
            <h2 class="text-lg font-semibold mb-4 dark:text-white">About the event</h2>
            <div class="text-gray-700 dark:text-gray-300 prose max-w-none dark:prose-invert">
              <% if @event.description.present? %>
                <p><%= simple_format(h(@event.description)) %></p>
              <% else %>
                <p class="text-gray-500 dark:text-gray-400 italic">No description provided.</p>
              <% end %>
            </div>
          </div>
          <div class="mt-8">
            <h2 class="text-lg font-semibold mb-4 dark:text-white">Organizer</h2>
            <div class="flex items-center">
              <div class="w-10 h-10 rounded-full bg-blue-100 dark:bg-blue-700 flex items-center justify-center text-blue-600 dark:text-blue-300 font-medium">
                <%= @event.created_by.email_address[0].upcase %>
              </div>
              <div class="ml-3">
                <p class="text-gray-900 dark:text-white font-medium"><%= @event.created_by.email_address %></p>
                <p class="text-gray-500 dark:text-gray-400 text-sm">Organizer</p>
              </div>
            </div>
          </div>
        </div>
        <div>
          <div class="bg-gray-50 dark:bg-gray-700 p-4 rounded-lg mb-6">
            <% if @is_participant %>
              <div class="text-center mb-4">
                <div class="inline-flex items-center px-4 py-2 bg-green-100 text-green-800 rounded-full">
                  <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                  </svg>
                  You're attending
                </div>
              </div>
              <div class="space-y-2">
                <%= button_to "Leave Event", community_event_event_participant_path(@community, @event, @participant), 
                    method: :delete, 
                    class: "w-full bg-red-600 hover:bg-red-700 text-white font-medium py-2 px-4 rounded-lg" %>
                <% if @participant.status != 'maybe' %>
                  <%= button_to "Change to Maybe", community_event_event_participant_path(@community, @event, @participant), 
                      method: :patch, 
                      params: { event_participant: { status: 'maybe' } },
                      class: "w-full bg-yellow-500 hover:bg-yellow-600 text-white font-medium py-2 px-4 rounded-lg" %>
                <% end %>
                <% if @participant.status != 'attending' %>
                  <%= button_to "Change to Attending", community_event_event_participant_path(@community, @event, @participant), 
                      method: :patch, 
                      params: { event_participant: { status: 'attending' } },
                      class: "w-full bg-green-600 hover:bg-green-700 text-white font-medium py-2 px-4 rounded-lg" %>
                <% end %>
              </div>
            <% elsif @can_join %>
              <div class="space-y-2">
                <%= button_to "Join Event", community_event_event_participants_path(@community, @event), 
                    method: :post, 
                    params: { status: 'attending' },
                    class: "w-full bg-blue-600 hover:bg-blue-700 text-white font-medium py-2 px-4 rounded-lg" %>
                <%= button_to "Maybe", community_event_event_participants_path(@community, @event), 
                    method: :post, 
                    params: { status: 'maybe' },
                    class: "w-full bg-yellow-500 hover:bg-yellow-600 text-white font-medium py-2 px-4 rounded-lg" %>
              </div>
            <% else %>
              <div class="text-center p-3 bg-amber-100 text-amber-800 rounded-lg">
                <p>This is a private event for community members only.</p>
                <% unless Current.user.member_of?(@community) %>
                  <div class="mt-2">
                    <%= link_to "Join Community", community_path(@community), class: "text-blue-600 hover:text-blue-800 font-medium" %>
                  </div>
                <% end %>
              </div>
            <% end %>
          </div>
          <div>
            <h2 class="text-lg font-semibold mb-4 dark:text-white">
              <%= @attendees.count %> <%= 'Attendee'.pluralize(@attendees.count) %>
            </h2>
            <% if @attendees.any? %>
              <ul class="space-y-3 max-h-60 overflow-y-auto pr-2">
                <% @attendees.each do |user| %>
                  <li class="flex items-center">
                    <div class="w-8 h-8 rounded-full bg-gray-200 dark:bg-gray-600 flex items-center justify-center text-xs font-medium">
                      <%= user.email_address[0].upcase %>
                    </div>
                    <span class="ml-2 text-gray-700 dark:text-gray-300"><%= user.email_address %></span>
                    <% if user.id == @event.created_by_id %>
                      <span class="ml-2 bg-blue-100 text-blue-800 text-xs font-medium px-2 py-0.5 rounded">Host</span>
                    <% end %>
                  </li>
                <% end %>
              </ul>
            <% else %>
              <p class="text-gray-500 dark:text-gray-400">No attendees yet.</p>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
