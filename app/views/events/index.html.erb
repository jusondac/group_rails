<div class="container px-4 py-8 mx-auto">
  <div class="flex justify-between items-center mb-6">
    <div>
      <h1 class="text-2xl font-bold dark:text-white">Events for <%= @community.name %></h1>
      <p class="text-gray-600 dark:text-gray-400 mt-1">Discover and join events in this community</p>
    </div>
    <div class="flex gap-2">
      <%= link_to "Back to Community", community_path(@community), class: "text-gray-600 bg-white border border-gray-300 hover:bg-gray-100 font-medium rounded-lg text-sm px-4 py-2 dark:bg-gray-800 dark:text-white dark:border-gray-600 dark:hover:bg-gray-700" %>
      <% if @user_is_admin %>
        <%= link_to "Create New Event", new_community_event_path(@community), class: "bg-blue-600 hover:bg-blue-700 text-white font-medium py-2 px-4 rounded-lg" %>
      <% end %>
    </div>
  </div>
  <% if @upcoming_events.any? %>
    <div class="mb-8">
      <h2 class="text-xl font-semibold mb-4 dark:text-white">Upcoming Events</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <% @upcoming_events.each do |event| %>
          <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 overflow-hidden flex flex-col h-full">
            <div class="p-5">
              <div class="flex justify-between items-start">
                <h3 class="text-lg font-semibold dark:text-white mb-2"><%= event.name %></h3>
                <% if event.private? %>
                  <span class="bg-amber-100 text-amber-800 text-xs font-medium px-2.5 py-0.5 rounded">Private</span>
                <% else %>
                  <span class="bg-green-100 text-green-800 text-xs font-medium px-2.5 py-0.5 rounded">Public</span>
                <% end %>
              </div>
              <div class="flex items-center text-sm text-gray-600 dark:text-gray-400 mt-2">
                <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd"></path></svg>
                <%= event.start_date.strftime('%b %d, %Y, %l:%M %p') %>
              </div>
              <% if event.location.present? %>
                <div class="flex items-center text-sm text-gray-600 dark:text-gray-400 mt-1">
                  <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"></path></svg>
                  <%= event.location %>
                </div>
              <% end %>
              <p class="text-gray-600 dark:text-gray-400 mt-2 text-sm line-clamp-2"><%= event.description %></p>
              <div class="mt-4">
                <div class="flex -space-x-2">
                  <% event.users.limit(5).each_with_index do |user, index| %>
                    <div class="z-<%= 50 - index %> w-7 h-7 rounded-full ring-2 ring-white dark:ring-gray-800 bg-gray-200 dark:bg-gray-600 flex items-center justify-center text-xs font-medium">
                      <%= user.email_address[0].upcase %>
                    </div>
                  <% end %>
                  <% if event.users.count > 5 %>
                    <div class="z-0 w-7 h-7 rounded-full ring-2 ring-white dark:ring-gray-800 bg-gray-200 dark:bg-gray-600 flex items-center justify-center text-xs font-medium">
                      +<%= event.users.count - 5 %>
                    </div>
                  <% end %>
                </div>
              </div>
            </div>
            <div class="mt-auto p-4 bg-gray-50 dark:bg-gray-700 border-t border-gray-200 dark:border-gray-700">
              <%= link_to "View Details", community_event_path(@community, event), class: "w-full inline-block text-center text-blue-600 hover:text-blue-700 font-medium dark:text-blue-400 dark:hover:text-blue-300" %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% else %>
    <div class="text-center py-8 my-4 bg-gray-50 dark:bg-gray-800 rounded-lg">
      <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
      </svg>
      <h3 class="mt-2 text-sm font-medium text-gray-900 dark:text-white">No upcoming events</h3>
      <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
        There are no upcoming events scheduled for this community.
      </p>
      <% if @user_is_admin %>
        <div class="mt-6">
          <%= link_to "Create New Event", new_community_event_path(@community), class: "bg-blue-600 hover:bg-blue-700 text-white font-medium py-2 px-4 rounded-lg" %>
        </div>
      <% end %>
    </div>
  <% end %>
  <% if @past_events.any? %>
    <div>
      <h2 class="text-xl font-semibold mb-4 dark:text-white">Past Events</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm text-left text-gray-500 dark:text-gray-400">
          <thead class="text-xs text-gray-700 uppercase bg-gray-50 dark:bg-gray-700 dark:text-gray-400">
            <tr>
              <th scope="col" class="px-6 py-3">Event</th>
              <th scope="col" class="px-6 py-3">Date</th>
              <th scope="col" class="px-6 py-3">Location</th>
              <th scope="col" class="px-6 py-3">Participants</th>
              <th scope="col" class="px-6 py-3">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% @past_events.each do |event| %>
              <tr class="bg-white border-b dark:bg-gray-800 dark:border-gray-700">
                <td class="px-6 py-4 font-medium text-gray-900 whitespace-nowrap dark:text-white">
                  <%= event.name %>
                  <% if event.private? %>
                    <span class="bg-amber-100 text-amber-800 text-xs font-medium px-2 py-0.5 rounded ml-2">Private</span>
                  <% end %>
                </td>
                <td class="px-6 py-4"><%= event.start_date.strftime('%b %d, %Y') %></td>
                <td class="px-6 py-4"><%= event.location.present? ? event.location : "-" %></td>
                <td class="px-6 py-4"><%= event.users.count %></td>
                <td class="px-6 py-4">
                  <%= link_to "View", community_event_path(@community, event), class: "font-medium text-blue-600 dark:text-blue-500 hover:underline" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  <% end %>
</div>
