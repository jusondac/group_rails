<div class="container px-4 py-8 mx-auto dark:bg-gray-900">
  <!-- Breadcrumb Navigation -->
  <div class="flex items-center gap-2 text-gray-500 dark:text-gray-400 mb-6">
    <%= link_to @community.name, community_path(@community), class: "hover:text-blue-600 dark:hover:text-blue-400" %>
    <svg class="w-3 h-3" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 6 10">
      <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 9 4-4-4-4"/>
    </svg>
    <%= link_to "Finance Settings", community_finance_path(@community), class: "hover:text-blue-600 dark:hover:text-blue-400" %>
    <svg class="w-3 h-3" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 6 10">
      <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 9 4-4-4-4"/>
    </svg>
    <span class="text-gray-700 dark:text-gray-300">Payments</span>
  </div>
  <!-- Header Section -->
  <div class="flex flex-col md:flex-row justify-between md:items-center mb-6">
    <div>
      <h1 class="text-2xl font-bold dark:text-white">Payment Management</h1>
      <p class="text-gray-600 dark:text-gray-400 mt-1">Track and manage all member payments</p>
    </div>
    <div class="mt-4 md:mt-0 flex flex-wrap gap-2">
      <%= link_to "Back to Finance Settings", community_finance_path(@community), class: "text-gray-600 dark:text-gray-300 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 hover:bg-gray-100 dark:hover:bg-gray-700 font-medium rounded-lg text-sm px-4 py-2" %>
      <%= link_to "Generate Payments", generate_payments_community_finance_path(@community), method: :post, class: "bg-blue-600 hover:bg-blue-700 dark:bg-blue-500 dark:hover:bg-blue-600 text-white font-medium py-2 px-4 rounded-lg", data: { turbo_method: :post, turbo_confirm: "This will generate payments for all members. Continue?" } %>
    </div>
  </div>
  <!-- Simple Tabs -->
  <div class="mb-4 border-b border-gray-200 dark:border-gray-700">
    <ul class="flex flex-wrap -mb-px text-sm font-medium text-center" id="payment-tabs">
      <li class="mr-2">
        <button onclick="showTab('pending')" class="tab-button inline-block p-4 border-b-2 rounded-t-lg active dark:text-gray-400 dark:hover:text-gray-300" data-tab="pending">
          Pending 
          <span class="bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-300 text-xs font-medium ml-2 px-2.5 py-0.5 rounded">
            <%= @pending_payments.count %>
          </span>
        </button>
      </li>
      <li class="mr-2">
        <button onclick="showTab('paid')" class="tab-button inline-block p-4 border-b-2 border-transparent rounded-t-lg hover:text-gray-600 hover:border-gray-300 dark:text-gray-400 dark:hover:text-gray-300" data-tab="paid">
          Paid
          <span class="bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-300 text-xs font-medium ml-2 px-2.5 py-0.5 rounded">
            <%= @paid_payments.count %>
          </span>
        </button>
      </li>
      <li>
        <button onclick="showTab('overdue')" class="tab-button inline-block p-4 border-b-2 border-transparent rounded-t-lg hover:text-gray-600 hover:border-gray-300 dark:text-gray-400 dark:hover:text-gray-300" data-tab="overdue">
          Overdue
          <span class="bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-300 text-xs font-medium ml-2 px-2.5 py-0.5 rounded">
            <%= @overdue_payments.count %>
          </span>
        </button>
      </li>
    </ul>
  </div>
  <!-- Tab Contents -->
  <div id="tab-content">
    <!-- Pending Payments Tab -->
    <div id="pending" class="tab-pane">
      <% if @pending_payments.any? %>
        <div class="overflow-x-auto rounded-lg border border-gray-100 dark:border-gray-700 shadow-sm">
          <table class="w-full text-sm divide-y divide-gray-100 dark:divide-gray-700">
            <thead class="bg-gray-50 dark:bg-gray-800">
              <tr>
                <th scope="col" class="px-6 py-4 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Member</th>
                <th scope="col" class="px-6 py-4 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Amount</th>
                <th scope="col" class="px-6 py-4 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Due Date</th>
                <th scope="col" class="px-6 py-4 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Period</th>
                <th scope="col" class="px-6 py-4 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Actions</th>
              </tr>
            </thead>
            <tbody class="bg-white dark:bg-gray-900 divide-y divide-gray-100 dark:divide-gray-700">
              <% @pending_payments.each do |payment| %>
                <tr class="hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors">
                  <td class="px-6 py-4 whitespace-nowrap font-medium text-gray-800 dark:text-gray-200">
                    <%= payment.membership.user.email_address rescue "Unknown user" %>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap font-medium text-gray-900 dark:text-gray-100">$<%= payment.amount %></td>
                  <td class="px-6 py-4 whitespace-nowrap text-gray-700 dark:text-gray-300"><%= payment.due_date&.strftime("%b %d, %Y") %></td>
                  <td class="px-6 py-4 whitespace-nowrap text-gray-700 dark:text-gray-300"><%= payment.period %></td>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <%= button_to "Mark as Paid", mark_as_paid_payment_path(payment), method: :patch, 
                        class: "inline-flex items-center px-3 py-1.5 border border-blue-600 dark:border-blue-500 text-blue-600 dark:text-blue-500 rounded-md text-sm font-medium hover:bg-blue-50 dark:hover:bg-blue-900/50 transition-colors", 
                        data: { turbo_method: :patch } %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="text-center py-12 bg-white dark:bg-gray-800 rounded-lg border border-gray-100 dark:border-gray-700 shadow-sm">
          <svg class="mx-auto h-12 w-12 text-gray-400 dark:text-gray-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m-6-8h6M9 20h12a2 2 0 002-2V6a2 2 0 00-2-2H9a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
          <h3 class="mt-2 text-sm font-medium text-gray-900 dark:text-white">No pending payments</h3>
          <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
            <%= @memberships.any? ? "All members have paid their dues or no payments have been generated yet." : "There are no members in this community yet." %>
          </p>
          <!-- Debug Info for Admin -->
          <% if @is_admin %>
            <div class="bg-blue-50 dark:bg-blue-900 p-4 mt-4 rounded-lg mx-auto max-w-md">
              <h4 class="text-sm font-medium text-blue-900 dark:text-blue-100">Admin Information</h4>
              <ul class="list-disc pl-5 mt-2 text-xs text-blue-800 dark:text-blue-200">
                <li>Community Members: <%= @memberships.count %></li>
                <li>Approved Memberships: <%= @community.memberships.approved.count %></li>
                <li>Finance Setting: <%= @community.finance_setting ? 'Configured' : 'Not Configured' %></li>
                <% if @community.finance_setting %>
                  <li>Amount: $<%= @community.finance_setting.amount %></li>
                  <li>Frequency: <%= @community.finance_setting.frequency.capitalize %></li>
                  <li>Active: <%= @community.finance_setting.active? ? 'Yes' : 'No' %></li>
                <% end %>
              </ul>
            </div>
          <% end %>
          <div class="mt-6">
            <%= link_to "Generate Payments", generate_payments_community_finance_path(@community), method: :post, 
                class: "inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700 dark:bg-blue-500 dark:hover:bg-blue-600 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500", 
                data: { turbo_method: :post, turbo_confirm: "This will generate payments for all members. Continue?" } %>
          </div>
        </div>
      <% end %>
    </div>
    <!-- Paid Payments Tab -->
    <div id="paid" class="tab-pane hidden">
      <% if @paid_payments.any? %>
        <div class="overflow-x-auto rounded-lg border border-gray-100 dark:border-gray-700 shadow-sm">
          <table class="w-full text-sm divide-y divide-gray-100 dark:divide-gray-700">
            <thead class="bg-gray-50 dark:bg-gray-800">
              <tr>
                <th scope="col" class="px-6 py-4 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Member</th>
                <th scope="col" class="px-6 py-4 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Amount</th>
                <th scope="col" class="px-6 py-4 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Paid Date</th>
                <th scope="col" class="px-6 py-4 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Period</th>
              </tr>
            </thead>
            <tbody class="bg-white dark:bg-gray-900 divide-y divide-gray-100 dark:divide-gray-700">
              <% @paid_payments.each do |payment| %>
                <tr class="hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors">
                  <td class="px-6 py-4 whitespace-nowrap font-medium text-gray-800 dark:text-gray-200">
                    <%= payment.membership.user.email_address rescue "Unknown user" %>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap font-medium text-gray-900 dark:text-gray-100">$<%= payment.amount %></td>
                  <td class="px-6 py-4 whitespace-nowrap text-gray-700 dark:text-gray-300"><%= payment.paid_at&.strftime("%b %d, %Y") %></td>
                  <td class="px-6 py-4 whitespace-nowrap text-gray-700 dark:text-gray-300"><%= payment.period %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="text-center py-12 bg-white dark:bg-gray-800 rounded-lg border border-gray-100 dark:border-gray-700 shadow-sm">
          <svg class="mx-auto h-12 w-12 text-gray-400 dark:text-gray-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m-6-8h6M9 20h12a2 2 0 002-2V6a2 2 0 00-2-2H9a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
          <h3 class="mt-2 text-sm font-medium text-gray-900 dark:text-white">No paid payments</h3>
          <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
            There are currently no paid payments.
          </p>
        </div>
      <% end %>
    </div>
    <!-- Overdue Payments Tab -->
    <div id="overdue" class="tab-pane hidden">
      <% if @overdue_payments.any? %>
        <div class="overflow-x-auto rounded-lg border border-gray-100 dark:border-gray-700 shadow-sm">
          <table class="w-full text-sm divide-y divide-gray-100 dark:divide-gray-700">
            <thead class="bg-gray-50 dark:bg-gray-800">
              <tr>
                <th scope="col" class="px-6 py-4 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Member</th>
                <th scope="col" class="px-6 py-4 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Amount</th>
                <th scope="col" class="px-6 py-4 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Due Date</th>
                <th scope="col" class="px-6 py-4 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Period</th>
                <th scope="col" class="px-6 py-4 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Days Overdue</th>
                <th scope="col" class="px-6 py-4 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Actions</th>
              </tr>
            </thead>
            <tbody class="bg-white dark:bg-gray-900 divide-y divide-gray-100 dark:divide-gray-700">
              <% @overdue_payments.each do |payment| %>
                <tr class="hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors">
                  <td class="px-6 py-4 whitespace-nowrap font-medium text-gray-800 dark:text-gray-200">
                    <%= payment.membership.user.email_address rescue "Unknown user" %>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap font-medium text-gray-900 dark:text-gray-100">$<%= payment.amount %></td>
                  <td class="px-6 py-4 whitespace-nowrap text-gray-700 dark:text-gray-300"><%= payment.due_date&.strftime("%b %d, %Y") %></td>
                  <td class="px-6 py-4 whitespace-nowrap text-gray-700 dark:text-gray-300"><%= payment.period %></td>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <% if payment.due_date.present? %>
                      <% begin %>
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-300">
                          <%= (Date.today - payment.due_date.to_date).to_i %> days
                        </span>
                        <% rescue %>
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-300">Invalid date</span>
                      <% end %>
                    <% else %>
                      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-300">Invalid date</span>
                    <% end %>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <%= button_to "Mark as Paid", mark_as_paid_payment_path(payment), method: :patch, 
                        class: "inline-flex items-center px-3 py-1.5 border border-blue-600 dark:border-blue-500 text-blue-600 dark:text-blue-500 rounded-md text-sm font-medium hover:bg-blue-50 dark:hover:bg-blue-900/50 transition-colors", 
                        data: { turbo_method: :patch } %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="text-center py-12 bg-white dark:bg-gray-800 rounded-lg border border-gray-100 dark:border-gray-700 shadow-sm">
          <svg class="mx-auto h-12 w-12 text-gray-400 dark:text-gray-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m-6-8h6M9 20h12a2 2 0 002-2V6a2 2 0 00-2-2H9a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
          <h3 class="mt-2 text-sm font-medium text-gray-900 dark:text-white">No overdue payments</h3>
          <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
            There are currently no overdue payments.
          </p>
        </div>
      <% end %>
    </div>
  </div>
</div>
<script>
  document.addEventListener('turbo:load', function() {
    showTab('pending');
  });

  document.addEventListener('DOMContentLoaded', function() {
    showTab('pending');
  });

  function showTab(tabId) {
    // Hide all tab panes
    document.querySelectorAll('.tab-pane').forEach(function(pane) {
      pane.classList.add('hidden');
    });

    // Show the selected tab pane
    const selectedPane = document.getElementById(tabId);
    if (selectedPane) {
      selectedPane.classList.remove('hidden');
    }

    // Update tab button styling
    document.querySelectorAll('.tab-button').forEach(function(button) {
      button.classList.remove('text-blue-600', 'border-blue-600', 'active');
      button.classList.add('border-transparent');
    });

    // Highlight active tab
    const activeButton = document.querySelector(`.tab-button[data-tab="${tabId}"]`);
    if (activeButton) {
      activeButton.classList.add('text-blue-600', 'border-blue-600', 'active');
      activeButton.classList.remove('border-transparent');
    }
  }
</script>
