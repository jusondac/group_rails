<div class="container px-4 py-8 mx-auto">
  <div class="flex items-center gap-2 text-gray-500 dark:text-gray-400 mb-6">
    <%= link_to @community.name, community_path(@community), class: "hover:text-blue-600 dark:hover:text-blue-400" %>
    <svg class="w-3 h-3" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 6 10">
      <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 9 4-4-4-4"/>
    </svg>
    <span class="text-gray-700 dark:text-gray-300">Finance Settings</span>
  </div>
  <div class="flex flex-col md:flex-row justify-between md:items-center mb-6">
    <div>
      <h1 class="text-2xl font-bold dark:text-white">Finance Settings</h1>
      <p class="text-gray-600 dark:text-gray-400 mt-1">Configure membership fees and payment settings</p>
    </div>
    <div class="mt-4 md:mt-0 flex flex-wrap gap-2">
      <%= link_to "Back to Community", community_path(@community), class: "text-gray-600 bg-white border border-gray-300 hover:bg-gray-100 font-medium rounded-lg text-sm px-4 py-2 dark:bg-gray-800 dark:text-white dark:border-gray-600 dark:hover:bg-gray-700" %>
      <%= link_to "View Payments", payments_community_finance_path(@community), class: "bg-blue-600 hover:bg-blue-700 text-white font-medium py-2 px-4 rounded-lg" %>
    </div>
  </div>
  <div class="grid grid-cols-1 lg:grid-cols-4 gap-6 mb-8">
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 p-6">
      <div class="flex items-center">
        <div class="inline-flex items-center justify-center p-2 bg-blue-100 rounded-md dark:bg-blue-900 mr-3">
          <svg class="w-6 h-6 text-blue-600 dark:text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
          </svg>
        </div>
        <div>
          <p class="text-sm font-medium text-gray-600 dark:text-gray-400">Total Members</p>
          <p class="text-xl font-semibold dark:text-white"><%= @total_members %></p>
        </div>
      </div>
    </div>
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 p-6">
      <div class="flex items-center">
        <div class="inline-flex items-center justify-center p-2 bg-green-100 rounded-md dark:bg-green-900 mr-3">
          <svg class="w-6 h-6 text-green-600 dark:text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
        </div>
        <div>
          <p class="text-sm font-medium text-gray-600 dark:text-gray-400">Total Collected</p>
          <p class="text-xl font-semibold dark:text-white">$<%= @total_collected || 0 %></p>
        </div>
      </div>
    </div>
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 p-6">
      <div class="flex items-center">
        <div class="inline-flex items-center justify-center p-2 bg-blue-100 rounded-md dark:bg-blue-900 mr-3">
          <svg class="w-6 h-6 text-blue-600 dark:text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
        </div>
        <div>
          <p class="text-sm font-medium text-gray-600 dark:text-gray-400">Paid Payments</p>
          <p class="text-xl font-semibold dark:text-white"><%= @total_paid || 0 %></p>
        </div>
      </div>
    </div>
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 p-6">
      <div class="flex items-center">
        <div class="inline-flex items-center justify-center p-2 bg-amber-100 rounded-md dark:bg-amber-900 mr-3">
          <svg class="w-6 h-6 text-amber-600 dark:text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
        </div>
        <div>
          <p class="text-sm font-medium text-gray-600 dark:text-gray-400">Pending Payments</p>
          <p class="text-xl font-semibold dark:text-white"><%= @total_pending || 0 %></p>
        </div>
      </div>
    </div>
  </div>
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <div class="lg:col-span-1">
      <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 p-6">
        <h2 class="text-lg font-semibold mb-4 dark:text-white">Membership Fee Settings</h2>
        <% if @finance_setting.persisted? %>
          <%= form_with(model: @finance_setting, url: community_finance_path(@community), method: :patch, local: true) do |form| %>
            <div class="mb-4">
              <%= form.label :amount, "Fee Amount ($)", class: "block mb-2 text-sm font-medium text-gray-900 dark:text-white" %>
              <%= form.number_field :amount, min: 0, step: "0.01", class: "bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white dark:focus:ring-blue-500 dark:focus:border-blue-500", required: true %>
            </div>
            <div class="mb-4">
              <%= form.label :frequency, class: "block mb-2 text-sm font-medium text-gray-900 dark:text-white" %>
              <%= form.select :frequency, options_for_select([["Weekly", "weekly"], ["Monthly", "monthly"], ["Yearly", "yearly"]], @finance_setting.frequency), {}, class: "bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white dark:focus:ring-blue-500 dark:focus:border-blue-500" %>
            </div>
            <div class="mb-4 flex items-center">
              <%= form.check_box :active, class: "w-4 h-4 text-blue-600 bg-gray-100 border-gray-300 rounded focus:ring-blue-500 dark:focus:ring-blue-600 dark:ring-offset-gray-800 dark:focus:ring-offset-gray-800 focus:ring-2 dark:bg-gray-700 dark:border-gray-600" %>
              <%= form.label :active, "Active", class: "ml-2 text-sm font-medium text-gray-900 dark:text-white" %>
            </div>
            <div class="flex justify-between mt-6">
              <%= form.submit "Update Settings", class: "w-full text-white bg-blue-700 hover:bg-blue-800 focus:ring-4 focus:outline-none focus:ring-blue-300 font-medium rounded-lg text-sm px-5 py-2.5 text-center dark:bg-blue-600 dark:hover:bg-blue-700 dark:focus:ring-blue-800" %>
            </div>
          <% end %>
        <% else %>
          <%= form_with(model: @finance_setting, url: community_finance_path(@community), method: :post, local: true) do |form| %>
            <div class="mb-4">
              <%= form.label :amount, "Fee Amount ($)", class: "block mb-2 text-sm font-medium text-gray-900 dark:text-white" %>
              <%= form.number_field :amount, min: 0, step: "0.01", class: "bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white dark:focus:ring-blue-500 dark:focus:border-blue-500", required: true, placeholder: "e.g. 10.00" %>
            </div>
            <div class="mb-4">
              <%= form.label :frequency, class: "block mb-2 text-sm font-medium text-gray-900 dark:text-white" %>
              <%= form.select :frequency, options_for_select([["Weekly", "weekly"], ["Monthly", "monthly"], ["Yearly", "yearly"]], "monthly"), {}, class: "bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white dark:focus:ring-blue-500 dark:focus:border-blue-500" %>
            </div>
            <div class="mb-4 flex items-center">
              <%= form.check_box :active, class: "w-4 h-4 text-blue-600 bg-gray-100 border-gray-300 rounded focus:ring-blue-500 dark:focus:ring-blue-600 dark:ring-offset-gray-800 dark:focus:ring-offset-gray-800 focus:ring-2 dark:bg-gray-700 dark:border-gray-600" %>
              <%= form.label :active, "Active", class: "ml-2 text-sm font-medium text-gray-900 dark:text-white" %>
              <div class="ml-2 text-xs text-gray-500 dark:text-gray-400">
                (Enable payment collection)
              </div>
            </div>
            <div class="flex justify-between mt-6">
              <%= form.submit "Enable Payments", class: "w-full text-white bg-blue-700 hover:bg-blue-800 focus:ring-4 focus:outline-none focus:ring-blue-300 font-medium rounded-lg text-sm px-5 py-2.5 text-center dark:bg-blue-600 dark:hover:bg-blue-700 dark:focus:ring-blue-800" %>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>
    <div class="lg:col-span-2">
      <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 p-6">
        <div class="flex justify-between items-center mb-4">
          <h2 class="text-lg font-semibold dark:text-white">Payment Management</h2>
          <% if @community.has_finance_enabled? %>
            <%= link_to "Generate Payments", generate_payments_community_finance_path(@community), method: :post, class: "text-white bg-blue-700 hover:bg-blue-800 focus:ring-4 focus:outline-none focus:ring-blue-300 font-medium rounded-lg text-xs px-3 py-2 text-center dark:bg-blue-600 dark:hover:bg-blue-700 dark:focus:ring-blue-800", data: { turbo_method: :post, turbo_confirm: "This will generate payments for all members. Continue?" } %>
          <% end %>
        </div>
        <% if @community.has_finance_enabled? %>
          <div class="overflow-x-auto">
            <table class="w-full text-sm text-left text-gray-500 dark:text-gray-400">
              <thead class="text-xs text-gray-700 uppercase bg-gray-50 dark:bg-gray-700 dark:text-gray-400">
                <tr>
                  <th scope="col" class="px-4 py-3">Member</th>
                  <th scope="col" class="px-4 py-3">Payment Status</th>
                  <th scope="col" class="px-4 py-3">Last Payment</th>
                  <th scope="col" class="px-4 py-3">Amount Paid</th>
                </tr>
              </thead>
              <tbody>
                <% @members.each do |membership| %>
                  <tr class="bg-white border-b dark:bg-gray-800 dark:border-gray-700">
                    <td class="px-4 py-3 font-medium text-gray-900 whitespace-nowrap dark:text-white">
                      <%= membership.user.email_address %>
                    </td>
                    <td class="px-4 py-3">
                      <% if membership.payments.paid.exists? %>
                        <span class="bg-green-100 text-green-800 text-xs font-medium px-2 py-0.5 rounded dark:bg-green-900 dark:text-green-300">Paid</span>
                      <% elsif membership.payments.pending.exists? %>
                        <span class="bg-yellow-100 text-yellow-800 text-xs font-medium px-2 py-0.5 rounded dark:bg-yellow-900 dark:text-yellow-300">Pending</span>
                      <% elsif membership.payments.overdue.exists? %>
                        <span class="bg-red-100 text-red-800 text-xs font-medium px-2 py-0.5 rounded dark:bg-red-900 dark:text-red-300">Overdue</span>
                      <% else %>
                        <span class="bg-gray-100 text-gray-800 text-xs font-medium px-2 py-0.5 rounded dark:bg-gray-700 dark:text-gray-300">No payments</span>
                      <% end %>
                    </td>
                    <td class="px-4 py-3">
                      <% last_payment = membership.payments.paid.order(paid_at: :desc).first %>
                      <%= last_payment ? last_payment.paid_at.strftime("%b %d, %Y") : "-" %>
                    </td>
                    <td class="px-4 py-3">
                      $<%= membership.payments.paid.sum(:amount) %>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% else %>
          <div class="text-center py-8 my-4 bg-gray-50 dark:bg-gray-700 rounded-lg">
            <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <h3 class="mt-2 text-sm font-medium text-gray-900 dark:text-white">No payment system enabled</h3>
            <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
              Configure the payment settings to start collecting membership fees.
            </p>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
