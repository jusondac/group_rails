<%# filepath: app/views/shared/_errors.html.erb %>
<div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-4">
  <p class="font-bold">The following errors prevented the <%= object.class.name.downcase %> from being saved:</p>
  <ul class="list-disc list-inside">
    <% object.errors.full_messages.each do |message| %>
      <li><%= message %></li>
    <% end %>
  </ul>
</div>
