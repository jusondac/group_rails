                      </svg>
                      <span class="flex-1 whitespace-nowrap text-sm">Finances</span>
                    </a>
                  </li>
                <% end %>
              <% end %>
              <% if Current.user.communities.count > 5 %>
                <li>
                  <a href="/communities" class="flex items-center p-2 text-gray-900 rounded-lg pl-11 dark:text-white hover:bg-gray-100 dark:hover:bg-gray-700 group">
                    <span class="flex-1 whitespace-nowrap text-blue-600 dark:text-blue-400 text-sm">View All →</span>
                  </a>
                </li>
              <% end %>
            <% end %>
          </ul>
        </li>
      </ul>
