              <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm0-14c-3.31 0-6 2.69-6 6s2.69 6 6 6 6-2.69 6-6-2.69-6-6-6zm0 10c-2.21 0-4-1.79-4-4s1.79-4 4-4 4 1.79 4 4-1.79 4-4 4z"></path>
            </svg>
            <span class="flex-1 ml-3 text-left whitespace-nowrap" sidebar-toggle-item="">Communities</span>
            <svg sidebar-toggle-item="" class="w-6 h-6" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
              <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd"></path>
            </svg>
          </button>
          <ul id="dropdown-communities" class="py-2 space-y-2">
            <li>
              <a href="/communities" class="flex items-center p-2 text-gray-900 rounded-lg pl-11 dark:text-white hover:bg-gray-100 dark:hover:bg-gray-700 group">
                <span class="flex-1 whitespace-nowrap">All Communities</span>
              </a>
            </li>
            <li>
              <a href="/communities/new" class="flex items-center p-2 text-gray-900 rounded-lg pl-11 dark:text-white hover:bg-gray-100 dark:hover:bg-gray-700 group">
                <span class="flex-1 whitespace-nowrap">Create Community</span>
              </a>
            </li>
            <% if Current.user.communities.any? %>
              <li class="pt-2 pb-1">
                <span class="pl-11 text-xs text-gray-500 dark:text-gray-400">My Communities</span>
              </li>
              <% Current.user.communities.distinct.limit(5).each do |community| %>
                <li>
                  <a href="/communities/<%= community.id %>" class="flex items-center p-2 text-gray-900 rounded-lg pl-11 dark:text-white hover:bg-gray-100 dark:hover:bg-gray-700 group">
                    <span class="flex-1 whitespace-nowrap truncate"><%= community.name %></span>
                    <% if Current.user.admin_of?(community) %>
                      <span class="bg-purple-100 text-purple-800 text-xs font-medium px-2 py-0.5 rounded">Admin</span>
                    <% end %>
                  </a>
                </li>
                <li class="ml-2">
                  <a href="/communities/<%= community.id %>/events" class="flex items-center p-1 text-gray-600 rounded-lg pl-11 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-700 group">
                    <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
