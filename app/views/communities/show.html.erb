<%# filepath: app/views/communities/show.html.erb %>
<div class="container px-4 py-8 mx-auto">
  <div class="mb-6 flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold dark:text-white"><%= @community.name %></h1>
      <div class="mt-1">
        <% if @community.private? %>
          <span class="bg-amber-100 text-amber-800 text-xs font-medium px-2.5 py-0.5 rounded">Private</span>
        <% else %>
          <span class="bg-green-100 text-green-800 text-xs font-medium px-2.5 py-0.5 rounded">Public</span>
        <% end %>
      </div>
    </div>
    <div class="space-x-2">
      <% if @is_admin %>
        <%= link_to "Edit", edit_community_path(@community), class: "bg-blue-600 hover:bg-blue-700 text-white font-medium py-2 px-4 rounded-lg" %>
        <%= button_to "Delete", community_path(@community), method: :delete, 
            data: { confirm: "Are you sure you want to delete this community?" }, 
            class: "bg-red-600 hover:bg-red-700 text-white font-medium py-2 px-4 rounded-lg" %>
      <% elsif @membership && @membership.pending? %>
        <span class="bg-yellow-100 text-yellow-800 text-sm font-medium px-2.5 py-1.5 rounded">Membership Pending</span>
      <% elsif @is_member %>
        <%= button_to "Leave Community", community_membership_path(@community, @membership), 
            method: :delete, 
            data: { confirm: "Are you sure you want to leave this community?" }, 
            class: "bg-red-600 hover:bg-red-700 text-white font-medium py-2 px-4 rounded-lg" %>
      <% else %>
        <%= button_to "Join Community", community_memberships_path(@community), 
            method: :post, 
            class: "bg-green-600 hover:bg-green-700 text-white font-medium py-2 px-4 rounded-lg" %>
      <% end %>
    </div>
  </div>
  <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md p-6 mb-6 border border-gray-200 dark:border-gray-700">
    <h2 class="text-lg font-semibold mb-2 dark:text-white">Description</h2>
    <p class="text-gray-700 dark:text-gray-300"><%= @community.description.present? ? @community.description : "No description provided." %></p>
  </div>
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <div class="lg:col-span-2">
      <!-- Community Activity Section - NEW -->
      <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md p-6 mb-6 border border-gray-200 dark:border-gray-700">
        <h2 class="text-lg font-semibold mb-4 dark:text-white">Recent Activity</h2>
        <div class="space-y-4">
          <% if @community.events.any? || @community.memberships.where("created_at > ?", 7.days.ago).any? %>
            <div class="relative">
              <div class="absolute h-full w-0.5 bg-gray-200 dark:bg-gray-700 left-2"></div>
              <% if @community.events.where("created_at > ?", 14.days.ago).any? %>
                <% @community.events.where("created_at > ?", 14.days.ago).order(created_at: :desc).limit(3).each do |event| %>
                  <div class="ml-8 mb-4 relative">
                    <div class="absolute -left-6 mt-1.5 w-4 h-4 rounded-full bg-blue-500"></div>
                    <div class="text-sm text-gray-500 dark:text-gray-400 mb-1"><%= time_ago_in_words(event.created_at) %> ago</div>
                    <div class="p-3 bg-gray-50 dark:bg-gray-700 rounded-lg">
                      <p class="text-gray-700 dark:text-gray-300">
                        <span class="font-medium">New event created:</span> <%= link_to event.name, community_event_path(@community, event), class: "text-blue-600 hover:underline dark:text-blue-400" %>
                      </p>
                    </div>
                  </div>
                <% end %>
              <% end %>
              <% @community.memberships.where("created_at > ?", 14.days.ago).order(created_at: :desc).limit(3).each do |membership| %>
                <div class="ml-8 mb-4 relative">
                  <div class="absolute -left-6 mt-1.5 w-4 h-4 rounded-full bg-green-500"></div>
                  <div class="text-sm text-gray-500 dark:text-gray-400 mb-1"><%= time_ago_in_words(membership.created_at) %> ago</div>
                  <div class="p-3 bg-gray-50 dark:bg-gray-700 rounded-lg">
                    <p class="text-gray-700 dark:text-gray-300">
                      <span class="font-medium"><%= membership.user.email_address %></span>
                      <% if membership.status == "approved" %>
                        joined the community
                      <% else %>
                        requested to join
                      <% end %>
                    </p>
                  </div>
                </div>
              <% end %>
            </div>
          <% else %>
            <p class="text-gray-500 dark:text-gray-400">No recent activity in this community.</p>
          <% end %>
        </div>
      </div>
      <!-- Members Section -->
      <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md p-6 mb-6 border border-gray-200 dark:border-gray-700">
        <div class="flex justify-between items-center mb-4">
          <h2 class="text-lg font-semibold dark:text-white">Members (<%= @members_count %>)</h2>
          <% if @is_admin %>
            <%= link_to "Manage Members", "#", class: "text-blue-600 hover:text-blue-800 dark:text-blue-400 dark:hover:text-blue-300 text-sm" %>
          <% end %>
        </div>
        <% if @members.any? %>
          <div class="flex flex-wrap gap-4 mb-4">
            <% @members.each do |membership| %>
              <div class="flex items-center">
                <div class="w-10 h-10 rounded-full bg-blue-100 dark:bg-blue-700 flex items-center justify-center text-blue-600 dark:text-blue-300 font-medium">
                  <%= membership.user.email_address[0].upcase %>
                </div>
                <div class="ml-2">
                  <p class="text-sm font-medium text-gray-900 dark:text-white"><%= membership.user.email_address %></p>
                  <p class="text-xs text-gray-500 dark:text-gray-400">
                    <%= membership.role.capitalize %>
                    <% if membership.user == @community.memberships.where(role: "admin").first&.user %>
                      • Creator
                    <% end %>
                  </p>
                </div>
              </div>
            <% end %>
          </div>
          <% if @members_count > 10 %>
            <div class="text-center">
              <button class="text-sm text-blue-600 hover:text-blue-800 dark:text-blue-400 dark:hover:text-blue-300">
                View All Members
              </button>
            </div>
          <% end %>
        <% else %>
          <p class="text-gray-500 dark:text-gray-400">No members yet.</p>
        <% end %>
      </div>
      <!-- Upcoming Events Section -->
      <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md p-6 mb-6 border border-gray-200 dark:border-gray-700">
        <div class="flex justify-between items-center mb-4">
          <h2 class="text-lg font-semibold dark:text-white">Upcoming Events</h2>
          <%= link_to "View All", community_events_path(@community), class: "text-blue-600 hover:text-blue-800 dark:text-blue-400 dark:hover:text-blue-300 text-sm" %>
        </div>
        <% if @upcoming_events.any? %>
          <div class="space-y-4">
            <% @upcoming_events.each do |event| %>
              <div class="p-4 bg-gray-50 dark:bg-gray-700 rounded-lg">
                <div class="flex justify-between items-start">
                  <div>
                    <h3 class="font-medium text-gray-900 dark:text-white"><%= event.name %></h3>
                    <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">
                      <span class="flex items-center">
                        <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
                          <path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd"></path>
                        </svg>
                        <%= event.start_date.strftime("%b %d, %Y • %I:%M %p") %>
                      </span>
                    </p>
                    <% if event.location.present? %>
                      <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">
                        <span class="flex items-center">
                          <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
                            <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"></path>
                          </svg>
                          <%= event.location %>
                        </span>
                      </p>
                    <% end %>
                  </div>
                  <%= link_to "View Event", community_event_path(@community, event), class: "text-sm text-blue-600 hover:text-blue-800 dark:text-blue-400 dark:hover:text-blue-300" %>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <p class="text-gray-500 dark:text-gray-400">No upcoming events.</p>
          <% if @is_admin || @is_member %>
            <div class="mt-3">
              <%= link_to "Create Event", new_community_event_path(@community), class: "text-sm bg-blue-600 hover:bg-blue-700 text-white font-medium py-2 px-4 rounded-lg" %>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>
    <div class="lg:col-span-1">
      <!-- Community Stats -->
      <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md p-6 mb-6 border border-gray-200 dark:border-gray-700">
        <h2 class="text-lg font-semibold mb-4 dark:text-white">Community Stats</h2>
        <div class="grid grid-cols-2 gap-4">
          <div class="bg-gray-50 dark:bg-gray-700 p-4 rounded-lg text-center">
            <p class="text-xl font-bold text-gray-700 dark:text-gray-300"><%= @members_count %></p>
            <p class="text-sm text-gray-500 dark:text-gray-400">Members</p>
          </div>
          <div class="bg-gray-50 dark:bg-gray-700 p-4 rounded-lg text-center">
            <p class="text-xl font-bold text-gray-700 dark:text-gray-300"><%= @community.events.count %></p>
            <p class="text-sm text-gray-500 dark:text-gray-400">Events</p>
          </div>
          <div class="bg-gray-50 dark:bg-gray-700 p-4 rounded-lg text-center">
            <p class="text-xl font-bold text-gray-700 dark:text-gray-300"><%= @community.events.where("start_date > ?", Date.today).count %></p>
            <p class="text-sm text-gray-500 dark:text-gray-400">Upcoming</p>
          </div>
          <div class="bg-gray-50 dark:bg-gray-700 p-4 rounded-lg text-center">
            <p class="text-xl font-bold text-gray-700 dark:text-gray-300"><%= @community.events.where("start_date < ?", Date.today).count %></p>
            <p class="text-sm text-gray-500 dark:text-gray-400">Past Events</p>
          </div>
        </div>
        <% if @community.has_finance_enabled? && (Current.user.admin_of?(@community) || Current.user.member_of?(@community)) %>
          <div class="mt-5">
            <h3 class="text-sm font-medium dark:text-white mb-2 pb-2 border-b border-gray-200 dark:border-gray-700">Membership Fees</h3>
            <div class="flex justify-between mb-1">
              <span class="text-sm text-gray-600 dark:text-gray-400">Amount:</span>
              <span class="text-sm font-medium dark:text-white">$<%= @community.finance_setting.amount %></span>
            </div>
            <div class="flex justify-between">
              <span class="text-sm text-gray-600 dark:text-gray-400">Frequency:</span>
              <span class="text-sm font-medium dark:text-white"><%= @community.finance_setting.frequency.capitalize %></span>
            </div>
            <% if Current.user.admin_of?(@community) %>
              <div class="mt-3 text-right">
                <%= link_to "Finance Dashboard", community_finance_path(@community), class: "text-sm text-blue-600 hover:text-blue-800 dark:text-blue-400 dark:hover:text-blue-300" %>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
      <!-- About Creator Section - NEW -->
      <% if @community.creator.present? %>
        <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md p-6 mb-6 border border-gray-200 dark:border-gray-700">
          <h2 class="text-lg font-semibold mb-3 dark:text-white">About the Creator</h2>
          <div class="flex items-start">
            <div class="w-12 h-12 rounded-full bg-blue-100 dark:bg-blue-700 flex items-center justify-center text-blue-600 dark:text-blue-300 font-bold text-xl mr-3">
              <%= @community.creator.email_address[0].upcase %>
            </div>
            <div>
              <p class="font-medium text-gray-900 dark:text-white"><%= @community.creator.email_address %></p>
              <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">
                Created on <%= @community.created_at.strftime("%B %d, %Y") %>
              </p>
              <div class="mt-3">
                <% if @is_member && Current.user != @community.creator %>
                  <button class="text-sm text-blue-600 hover:text-blue-800 dark:text-blue-400 dark:hover:text-blue-300">
                    Message Creator
                  </button>
                <% end %>
              </div>
            </div>
          </div>
        </div>
      <% end %>
      <!-- Join/Action Section -->
      <% unless @is_member || @membership&.pending? %>
        <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md p-6 border border-gray-200 dark:border-gray-700">
          <h2 class="text-lg font-semibold mb-2 dark:text-white">Join Community</h2>
          <p class="text-gray-600 dark:text-gray-400 mb-4">Join this community to participate in discussions and events.</p>
          <%= button_to "Join Now", community_memberships_path(@community), 
              method: :post, 
              class: "w-full bg-green-600 hover:bg-green-700 text-white font-medium py-2 px-4 rounded-lg" %>
        </div>
      <% end %>
    </div>
  </div>
  <% if @is_admin && @pending_memberships.any? %>
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md p-6 mb-6 border border-gray-200 dark:border-gray-700">
      <h2 class="text-lg font-semibold mb-4 dark:text-white">Pending Membership Requests</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm text-left text-gray-500 dark:text-gray-400">
          <thead class="text-xs text-gray-700 uppercase bg-gray-50 dark:bg-gray-700 dark:text-gray-400">
            <tr>
              <th scope="col" class="px-6 py-3">User</th>
              <th scope="col" class="px-6 py-3">Requested At</th>
              <th scope="col" class="px-6 py-3">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% @pending_memberships.each do |membership| %>
              <tr class="bg-white border-b dark:bg-gray-800 dark:border-gray-700">
                <td class="px-6 py-4"><%= membership.user.email_address %></td>
                <td class="px-6 py-4"><%= membership.created_at.strftime("%b %d, %Y") %></td>
                <td class="px-6 py-4 flex space-x-2">
                  <%= button_to "Approve", approve_community_membership_path(@community, membership), 
                      method: :patch, 
                      class: "bg-green-600 hover:bg-green-700 text-white font-medium py-1 px-3 rounded text-xs" %>
                  <%= button_to "Reject", reject_community_membership_path(@community, membership), 
                      method: :patch, 
                      class: "bg-red-600 hover:bg-red-700 text-white font-medium py-1 px-3 rounded text-xs" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  <% end %>
  <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md p-6 border border-gray-200 dark:border-gray-700">
    <h2 class="text-lg font-semibold mb-4 dark:text-white">Members</h2>
    <div class="overflow-x-auto">
      <table class="w-full text-sm text-left text-gray-500 dark:text-gray-400">
        <thead class="text-xs text-gray-700 uppercase bg-gray-50 dark:bg-gray-700 dark:text-gray-400">
          <tr>
            <th scope="col" class="px-6 py-3">User</th>
            <th scope="col" class="px-6 py-3">Role</th>
            <th scope="col" class="px-6 py-3">Joined At</th>
            <% if @is_admin %>
              <th scope="col" class="px-6 py-3">Actions</th>
            <% end %>
          </tr>
        </thead>
        <tbody>
          <% @community.memberships.approved.includes(:user).each do |membership| %>
            <tr class="bg-white border-b dark:bg-gray-800 dark:border-gray-700">
              <td class="px-6 py-4"><%= membership.user.email_address %></td>
              <td class="px-6 py-4">
                <% if membership.admin? %>
                  <span class="bg-purple-100 text-purple-800 text-xs font-medium px-2.5 py-0.5 rounded">Admin</span>
                <% else %>
                  <span class="bg-blue-100 text-blue-800 text-xs font-medium px-2.5 py-0.5 rounded">Member</span>
                <% end %>
              </td>
              <td class="px-6 py-4"><%= membership.created_at.strftime("%b %d, %Y") %></td>
              <% if @is_admin && membership.user_id != Current.user.id %>
                <td class="px-6 py-4 flex space-x-2">
                  <% if membership.role == 'member' %>
                    <%= button_to "Make Admin", community_membership_path(@community, membership), 
                        method: :patch, 
                        params: { membership: { role: 'admin' } }, 
                        class: "bg-purple-600 hover:bg-purple-700 text-white font-medium py-1 px-3 rounded text-xs" %>
                  <% else %>
                    <%= button_to "Remove Admin", community_membership_path(@community, membership), 
                        method: :patch, 
                        params: { membership: { role: 'member' } }, 
                        class: "bg-blue-600 hover:bg-blue-700 text-white font-medium py-1 px-3 rounded text-xs" %>
                  <% end %>
                  <%= button_to "Remove", community_membership_path(@community, membership), 
                      method: :delete, 
                      data: { confirm: "Are you sure you want to remove this member?" }, 
                      class: "bg-red-600 hover:bg-red-700 text-white font-medium py-1 px-3 rounded text-xs" %>
                </td>
              <% elsif @is_admin %>
                <td class="px-6 py-4">
                  <span class="text-gray-500 italic text-xs">You</span>
                </td>
              <% end %>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
