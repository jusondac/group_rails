<%# filepath: app/views/communities/index.html.erb %>
<div class="container px-4 py-8 mx-auto">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold dark:text-white">Communities</h1>
    <%= link_to "Create New Community", new_community_path, class: "bg-blue-600 hover:bg-blue-700 text-white font-medium py-2 px-4 rounded-lg" %>
  </div>
  <% if @my_communities.any? %>
    <div class="mb-8">
      <h2 class="text-xl font-semibold mb-4 dark:text-white">My Communities</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        <% @my_communities.each do |community| %>
          <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md overflow-hidden border border-gray-200 dark:border-gray-700">
            <div class="p-4">
              <div class="flex justify-between items-start">
                <h3 class="text-lg font-medium dark:text-white"><%= community.name %></h3>
                <% if community.private? %>
                  <span class="bg-amber-100 text-amber-800 text-xs font-medium px-2.5 py-0.5 rounded">Private</span>
                <% else %>
                  <span class="bg-green-100 text-green-800 text-xs font-medium px-2.5 py-0.5 rounded">Public</span>
                <% end %>
              </div>
              <p class="text-gray-600 dark:text-gray-400 mt-2 text-sm line-clamp-2"><%= community.description %></p>
              <div class="mt-4 flex justify-between items-center">
                <%= link_to "View", community_path(community), class: "text-blue-600 hover:underline dark:text-blue-400" %>
                <% if Current.user.admin_of?(community) %>
                  <span class="bg-purple-100 text-purple-800 text-xs font-medium px-2.5 py-0.5 rounded">Admin</span>
                <% else %>
                  <span class="bg-blue-100 text-blue-800 text-xs font-medium px-2.5 py-0.5 rounded">Member</span>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
  <div>
    <h2 class="text-xl font-semibold mb-4 dark:text-white">Public Communities</h2>
    <% if @communities.any? %>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        <% @communities.each do |community| %>
          <% unless Current.user.communities.include?(community) %>
            <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md overflow-hidden border border-gray-200 dark:border-gray-700">
              <div class="p-4">
                <h3 class="text-lg font-medium dark:text-white"><%= community.name %></h3>
                <p class="text-gray-600 dark:text-gray-400 mt-2 text-sm line-clamp-2"><%= community.description %></p>
                <div class="mt-4 flex justify-between items-center">
                  <%= link_to "View", community_path(community), class: "text-blue-600 hover:underline dark:text-blue-400" %>
                  <%= button_to "Join", community_memberships_path(community), method: :post, class: "bg-green-600 hover:bg-green-700 text-white font-medium py-1 px-3 rounded-lg text-sm" %>
                </div>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <p class="text-gray-600 dark:text-gray-400">No public communities available.</p>
    <% end %>
  </div>
</div>
