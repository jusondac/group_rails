<%# filepath: /home/rejka/Desktop/gamifyrails/my_group/app/views/home/index.html.erb %>
<div class="min-h-screen bg-gray-50 dark:bg-gray-900">
  <div class="container px-4 py-8 mx-auto">
    <!-- Welcome Section -->
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-gray-900 dark:text-white">Welcome<% if Current.user %>, <%= Current.user.email_address.split('@').first %>!<% end %></h1>
      <p class="mt-2 text-gray-600 dark:text-gray-400">Manage your communities, events, and finances all in one place.</p>
    </div>

    <!-- Quick Stats Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
      <!-- Communities Card -->
      <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6">
        <div class="flex items-center justify-between">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white">My Communities</h2>
          <div class="p-2 bg-blue-100 dark:bg-blue-900 rounded-full">
            <svg class="w-6 h-6 text-blue-600 dark:text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
            </svg>
          </div>
        </div>
        <div class="mt-4">
          <p class="text-3xl font-bold text-gray-900 dark:text-white"><%= Current.user&.memberships&.count || 0 %></p>
          <p class="text-sm text-gray-500 dark:text-gray-400">Active memberships</p>
        </div>
        <%= link_to communities_path, class: "mt-4 inline-flex items-center text-sm font-medium text-blue-600 dark:text-blue-400 hover:text-blue-800 dark:hover:text-blue-300" do %>
          View all communities
          <svg class="ml-1 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        <% end %>
      </div>

      <!-- Events Card -->
      <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6">
        <div class="flex items-center justify-between">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Upcoming Events</h2>
          <div class="p-2 bg-green-100 dark:bg-green-900 rounded-full">
            <svg class="w-6 h-6 text-green-600 dark:text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
          </div>
        </div>
        <div class="mt-4">
          <p class="text-3xl font-bold text-gray-900 dark:text-white">
            <%= Event.joins(community: :memberships)
                    .where(memberships: { user: Current.user })
                    .where('start_date >= ?', Date.today).count %>
          </p>
          <p class="text-sm text-gray-500 dark:text-gray-400">Upcoming events</p>
        </div>
        <div class="mt-4 space-y-1">
          <% Current.user&.memberships&.includes(:community)&.each do |membership| %>
            <%= link_to membership.community.name, community_events_path(membership.community), class: "block text-green-600 dark:text-green-400 hover:text-green-800 dark:hover:text-green-300 text-sm font-medium" %>
          <% end %>
        </div>
      </div>

      <!-- Finance Card -->
      <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6">
        <div class="flex items-center justify-between">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Financial Overview</h2>
          <div class="p-2 bg-purple-100 dark:bg-purple-900 rounded-full">
            <svg class="w-6 h-6 text-purple-600 dark:text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
        </div>
        <div class="mt-4">
          <p class="text-3xl font-bold text-gray-900 dark:text-white">
            <%= Current.user&.memberships&.joins(:payments)&.where(payments: { status: 'pending' })&.count || 0 %>
          </p>
          <p class="text-sm text-gray-500 dark:text-gray-400">Pending payments</p>
        </div>
        <div class="mt-4 space-y-1">
          <% Current.user&.memberships&.includes(:community)&.each do |membership| %>
            <%= link_to membership.community.name, community_finance_path(membership.community), class: "block text-purple-600 dark:text-purple-400 hover:text-purple-800 dark:hover:text-purple-300 text-sm font-medium" %>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Recent Activity Section -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      <!-- Recent Events -->
      <div class="bg-white dark:bg-gray-800 rounded-lg shadow">
        <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Recent Events</h2>
        </div>
        <div class="p-6">
          <% recent_events = Event.joins(community: :memberships)
                .where(memberships: { user: Current.user })
                .order(start_date: :desc)
                .limit(5) %>
          
          <% if recent_events.any? %>
            <div class="space-y-4">
              <% recent_events.each do |event| %>
                <div class="flex items-center space-x-4">
                  <div class="flex-shrink-0">
                    <div class="p-2 bg-green-100 dark:bg-green-900 rounded-full">
                      <svg class="w-5 h-5 text-green-600 dark:text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                      </svg>
                    </div>
                  </div>
                  <div class="min-w-0 flex-1">
                    <p class="text-sm font-medium text-gray-900 dark:text-white truncate">
                      <%= event.name %>
                    </p>
                    <p class="text-sm text-gray-500 dark:text-gray-400">
                      <%= event.start_date.strftime("%b %d, %Y") %>
                    </p>
                  </div>
                </div>
              <% end %>
            </div>
          <% else %>
            <p class="text-gray-500 dark:text-gray-400 text-sm">No recent events found.</p>
          <% end %>
        </div>
      </div>

      <!-- Recent Payments -->
      <div class="bg-white dark:bg-gray-800 rounded-lg shadow">
        <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Recent Payments</h2>
        </div>
        <div class="p-6">
          <% recent_payments = Payment.joins(:membership)
                .where(memberships: { user: Current.user })
                .order(due_date: :desc)
                .limit(5) %>
          
          <% if recent_payments.any? %>
            <div class="space-y-4">
              <% recent_payments.each do |payment| %>
                <div class="flex items-center space-x-4">
                  <div class="flex-shrink-0">
                    <div class="p-2 rounded-full <%= payment.status == 'paid' ? 'bg-green-100 dark:bg-green-900' : 'bg-yellow-100 dark:bg-yellow-900' %>">
                      <svg class="w-5 h-5 <%= payment.status == 'paid' ? 'text-green-600 dark:text-green-400' : 'text-yellow-600 dark:text-yellow-400' %>" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                      </svg>
                    </div>
                  </div>
                  <div class="min-w-0 flex-1">
                    <p class="text-sm font-medium text-gray-900 dark:text-white truncate">
                      <%= payment.membership.community.name %>
                    </p>
                    <p class="text-sm text-gray-500 dark:text-gray-400">
                      $<%= payment.amount %> - <%= payment.status.capitalize %>
                    </p>
                  </div>
                  <div class="text-sm text-gray-500 dark:text-gray-400">
                    <%= payment.due_date.strftime("%b %d") %>
                  </div>
                </div>
              <% end %>
            </div>
          <% else %>
            <p class="text-gray-500 dark:text-gray-400 text-sm">No recent payments found.</p>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Logout Button -->
    <div class="mt-8 flex justify-end">
      <%= button_to "Log out", session_path, method: :delete, 
          class: "px-4 py-2 bg-gray-200 dark:bg-gray-700 text-gray-700 dark:text-gray-300 rounded-lg hover:bg-gray-300 dark:hover:bg-gray-600 transition-colors" %>
    </div>
  </div>
</div>
